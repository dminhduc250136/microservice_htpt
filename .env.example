MAIL_SMTP_HOST=
MAIL_SMTP_PORT=
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
# URL trình duyệt truy cập frontend — dùng trong link email (verify/reset password).
# VM: http://74.226.89.57:3000
APP_BASE_URL=
JWT_SECRET=

# Google OAuth (Login with Google)
# GOOGLE_CLIENT_ID: backend verify audience của ID token (user-service)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID: frontend khởi tạo nút Google — phải CÙNG giá trị, bake lúc build
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# URL trình duyệt gọi API Gateway — bake vào bundle frontend lúc build.
# VM: http://74.226.89.57:8080
NEXT_PUBLIC_API_BASE_URL=

# Origin frontend được phép gọi gateway (CSV). VM: http://74.226.89.57:3000
CORS_ALLOWED_ORIGINS=

# API key cho chat AI (frontend BFF route gọi Anthropic)
ANTHROPIC_API_KEY=

# Tunnel forward https://frying-skipping-handbook.ngrok-free.dev → localhost:8080 (api-gateway)
MOMO_IPN_URL=