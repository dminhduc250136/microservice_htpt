# ===== Domain + HTTPS (Caddy reverse proxy) =====
# SITE_ADDRESS: domain phục vụ qua HTTPS. VM: n24shop.io.vn
# ACME_EMAIL: email nhận thông báo gia hạn cert Let's Encrypt.
SITE_ADDRESS=
ACME_EMAIL=

# ===== URL công khai (trình duyệt) — same-origin qua domain, KHÔNG kèm port =====
# APP_BASE_URL: dùng trong link email (verify/reset password). VM: https://n24shop.io.vn
APP_BASE_URL=
# NEXT_PUBLIC_API_BASE_URL: trình duyệt gọi API qua đây — bake vào bundle lúc build.
# Same-origin: cùng domain, path /api/... → https://n24shop.io.vn
NEXT_PUBLIC_API_BASE_URL=
# Origin được phép gọi gateway (CSV). Same-origin nên ít khi kích hoạt. VM: https://n24shop.io.vn
CORS_ALLOWED_ORIGINS=

# ===== JWT (user-service issue, gateway verify — phải trùng nhau) =====
JWT_SECRET=

# ===== Google OAuth (Login with Google) =====
# Authorized JavaScript origin trên Google Console PHẢI là domain HTTPS (vd https://n24shop.io.vn).
# GOOGLE_CLIENT_ID: backend verify audience ID token. NEXT_PUBLIC_*: frontend (bake lúc build).
# Hai biến PHẢI cùng giá trị.
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ===== Chat AI =====
ANTHROPIC_API_KEY=

# ===== Email (SMTP) =====
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=

# ===== MoMo =====
# RETURN: redirect trình duyệt user → dùng domain thật, vd https://n24shop.io.vn/checkout/result
# IPN: server→server. MoMo sandbox KHÔNG gọi IPN tới domain thật (.io.vn / azure cloudapp
#   đều bị bỏ qua) → PHẢI dùng ngrok static domain trỏ về :80 trên VM.
#   vd: https://<your-static>.ngrok-free.dev/api/payments/momo/ipn
MOMO_IPN_URL=
MOMO_RETURN_URL=

VM_SSH_PASSWORD=
